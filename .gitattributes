# Normalize line endings on checkin
* text=auto eol=lf

# Binary files (no line-ending normalization, no text diffs)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Generated / vendored files — collapse in PR diffs by default
package-lock.json linguist-generated=true
*.snap linguist-generated=true
